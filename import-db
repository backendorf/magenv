#!/bin/bash
set -eo pipefail

# Load environment variables
if [ -f .env ]; then
    set -a
    source .env
    set +a
else
    echo "❌ .env file not found! Please create it before running import."
    exit 1
fi

IMPORT_FILE="dumps/import.sql"

if [ ! -f "$IMPORT_FILE" ]; then
    echo "❌ Import file not found: $IMPORT_FILE"
    echo "Please place your SQL dump at $IMPORT_FILE and try again."
    exit 1
fi

echo "🚀 Importing database into ${MYSQL_DATABASE}...";

# Using the mapped volume path /dumps/import.sql inside the container
# We use docker compose exec to run mysql with the password from environment
docker compose exec -T db sh -c 'mysql -u root -p"$MYSQL_ROOT_PASSWORD" "$MYSQL_DATABASE" < /dumps/import.sql'

echo "✅ Database imported successfully!";
