# --- PROJECT ---
STORE_PREFIX=magenv
MAGENTO_BASE_URL=http://${STORE_PREFIX}.localhost/

# --- ENVIRONMENT ---
PHP_VERSION=8.4-fpm
PHP_MEMORY_LIMIT=4G
COMPOSER_CACHE_PATH=${HOME}/.composer
XDEBUG_VERSION=3.3.0

# --- DATABASE ---
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=${STORE_PREFIX}_db
MYSQL_USER=magento
MYSQL_PASSWORD=magento

# --- MAGENTO LOCALE ---
MAGENTO_ADMIN_USER=admin
MAGENTO_ADMIN_PASSWORD=admin123
MAGENTO_ADMIN_EMAIL=admin@admin.com
MAGENTO_ADMIN_FIRSTNAME=Admin
MAGENTO_ADMIN_LASTNAME=Admin
MAGENTO_ADMIN_FRONTNAME=admin

# --- MAGENTO LOCALE ---
MAGENTO_LANGUAGE=en_US
MAGENTO_CURRENCY=USD
MAGENTO_TIMEZONE=America/Chicago
