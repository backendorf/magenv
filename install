#!/bin/bash
set -eo pipefail

# function to load and evaluate .env
load_env() {
    if [ -f .env ]; then
        set -a
        source .env
        set +a
        STORE_PREFIX=$(eval echo "$STORE_PREFIX")
        MAGENTO_BASE_URL=$(eval echo "$MAGENTO_BASE_URL")
        MYSQL_DATABASE=$(eval echo "$MYSQL_DATABASE")
        MAGENTO_ADMIN_FRONTNAME=$(eval echo "$MAGENTO_ADMIN_FRONTNAME")
    else
        echo "❌ .env file not found! Please create it before running install."
        exit 1
    fi
}

load_env

# ── 1. Check if Magento is already installed ──────────────────────────────────
IS_INSTALLED=$(docker compose exec -T php [ -f /var/www/html/app/etc/env.php ] && echo "yes" || echo "no" | tr -d '\r')

if [ "$IS_INSTALLED" == "yes" ]; then
    echo "⚠️  Magento is already installed in this environment!"
    read -p "Do you want to reinstall it from scratch? (y/n): " REINSTALL
    if [ "$REINSTALL" != "y" ]; then
        echo "❌ Installation aborted."
        exit 0
    fi
    echo "🧹 Clearing current installation for a fresh start..."
    docker compose exec -T php find /var/www/html -mindepth 1 -delete
fi

# ── 2. Override Store Prefix ──────────────────────────────────────────────────
read -p "Enter Store Prefix [default: $STORE_PREFIX]: " INPUT_PREFIX
if [ ! -z "$INPUT_PREFIX" ]; then
    STORE_PREFIX=$INPUT_PREFIX
    echo "📝 Updating .env with new STORE_PREFIX: $STORE_PREFIX"
    sed -i "s/^STORE_PREFIX=.*/STORE_PREFIX=$STORE_PREFIX/" .env
    load_env
    echo "🔄 Refreshing containers for new prefix..."
    docker compose up -d --remove-orphans
fi

echo "🚀 Initializing Magento environment in ${STORE_PREFIX}"

# ── 3. Ask for distribution ───────────────────────────────────────────────────
echo ""
echo "Which distribution do you want to install?"
echo "  1) Magento (official Adobe repository)"
echo "  2) Mage-OS (community fork)"
read -p "Choose [1 or 2, default: 1]: " DISTRO_CHOICE
DISTRO_CHOICE=${DISTRO_CHOICE:-1}

if [ "$DISTRO_CHOICE" == "2" ]; then
    COMPOSER_REPO="https://mirror.mage-os.org/"
    COMPOSER_PACKAGE="magento/project-community-edition"
    DISTRO_LABEL="Mage-OS"
else
    COMPOSER_REPO="https://repo.magento.com/"
    COMPOSER_PACKAGE="magento/project-community-edition"
    DISTRO_LABEL="Magento (official)"
fi

echo "📦 Distribution selected: $DISTRO_LABEL"

# ── 4. Ask for version ────────────────────────────────────────────────────────
read -p "Enter Magento version (leave empty for latest): " VERSION

# ── 5. Ask for theme ──────────────────────────────────────────────────────────
echo ""
echo "Which theme do you want to use?"
echo "  1) Luma (default Magento theme)"
echo "  2) Hyvä"
read -p "Choose [1 or 2, default: 1]: " THEME_CHOICE
THEME_CHOICE=${THEME_CHOICE:-1}

if [ "$THEME_CHOICE" == "2" ]; then
    echo ""
    echo "🎨 Hyvä selected! Please provide your Hyvä Packagist credentials."
    echo "   (from hyva-themes.repo.packagist.com)"
    read -p "Username: " HYVA_USERNAME
    read -p "Password: " HYVA_PASSWORD

    if [ -z "$HYVA_USERNAME" ] || [ -z "$HYVA_PASSWORD" ]; then
        echo "❌ Username and password are required for Hyvä. Aborting."
        exit 1
    fi
fi

# ── 6. Ask for sample data ────────────────────────────────────────────────────
read -p "Install sample data? (y/n) [default: n]: " INSTALL_SAMPLE_DATA
INSTALL_SAMPLE_DATA=${INSTALL_SAMPLE_DATA:-n}

# ── 7. Ensure directory permissions ──────────────────────────────────────────
echo "🔐 Checking directory permissions..."
docker compose exec -T php sudo chown -R app:app /var/www/html

# ── 8. Handle partial installs ────────────────────────────────────────────────
IS_EMPTY=$(docker compose exec -T php ls -A /var/www/html | tr -d '\r')

if [ ! -z "$IS_EMPTY" ]; then
    HAS_COMPOSER=$(docker compose exec -T php [ -f /var/www/html/composer.json ] && echo "yes" || echo "no" | tr -d '\r')
    HAS_BIN_MAGENTO=$(docker compose exec -T php [ -f /var/www/html/bin/magento ] && echo "yes" || echo "no" | tr -d '\r')

    if [ "$HAS_COMPOSER" == "yes" ] && [ "$HAS_BIN_MAGENTO" == "no" ]; then
        echo "⚠️  Found composer.json but bin/magento is missing. Completing installation..."
        docker compose exec php composer install
    elif [ "$HAS_COMPOSER" == "no" ]; then
        echo "⚠️  Directory /var/www/html is not empty and no composer.json found!"
        read -p "Do you want to clear it and continue? (y/n): " CLEAR
        if [ "$CLEAR" == "y" ]; then
            echo "🧹 Clearing directory..."
            docker compose exec -T php find /var/www/html -mindepth 1 -delete
        else
            echo "❌ Installation aborted."
            exit 1
        fi
    fi
fi

# ── 9. Download Magento via Composer ──────────────────────────────────────────
if ! docker compose exec -T php [ -f /var/www/html/composer.json ]; then
    echo "📦 Downloading Magento files via Composer..."

    if [ -z "$VERSION" ]; then
        echo "🔹 No version specified, installing latest from $DISTRO_LABEL..."
        docker compose exec php composer create-project --repository-url=$COMPOSER_REPO $COMPOSER_PACKAGE . --no-install
    else
        echo "🔹 Installing version $VERSION from $DISTRO_LABEL..."
        docker compose exec php composer create-project --repository-url=$COMPOSER_REPO $COMPOSER_PACKAGE:$VERSION . --no-install
    fi

    docker compose exec php composer install
fi

# Ensure bin/magento is executable
docker compose exec -T php chmod +x bin/magento

# ── 10. Install Hyvä if selected ──────────────────────────────────────────────
if [ "$THEME_CHOICE" == "2" ]; then
    echo "🎨 Configuring Hyvä Packagist repository..."
    docker compose exec php composer config --auth http-basic.hyva-themes.repo.packagist.com "$HYVA_USERNAME" "$HYVA_PASSWORD"
    docker compose exec php composer config repositories.hyva-themes composer https://hyva-themes.repo.packagist.com

    echo "🎨 Installing Hyvä theme..."
    docker compose exec php composer require hyva-themes/magento2-default-theme
fi

# ── 11. Deploy sample data if requested ───────────────────────────────────────
if [ "$INSTALL_SAMPLE_DATA" == "y" ]; then
    echo "📊 Deploying Sample Data..."
    docker compose exec php bin/magento sampledata:deploy
fi

# ── 12. Ensure database exists ────────────────────────────────────────────────
echo "🏗️  Ensuring database ${MYSQL_DATABASE} exists..."
docker compose exec -T db sh -c "mysql -u root -p\"\$MYSQL_ROOT_PASSWORD\" -e \"CREATE DATABASE IF NOT EXISTS $MYSQL_DATABASE;\""

# ── 13. Run Magento setup:install ─────────────────────────────────────────────
echo "🏗️  Starting Magento installation..."

EXTRA_OPTS=""
if [ "$INSTALL_SAMPLE_DATA" == "y" ]; then
    EXTRA_OPTS="--use-sample-data"
fi

docker compose exec php bin/magento setup:install \
--base-url=${MAGENTO_BASE_URL} \
--db-host=db \
--db-name=${MYSQL_DATABASE} \
--db-user=root \
--db-password=${MYSQL_ROOT_PASSWORD} \
--admin-firstname=${MAGENTO_ADMIN_FIRSTNAME} \
--admin-lastname=${MAGENTO_ADMIN_LASTNAME} \
--admin-email=${MAGENTO_ADMIN_EMAIL} \
--admin-user=${MAGENTO_ADMIN_USER} \
--admin-password=${MAGENTO_ADMIN_PASSWORD} \
--language=${MAGENTO_LANGUAGE} \
--currency=${MAGENTO_CURRENCY} \
--timezone=${MAGENTO_TIMEZONE} \
--use-rewrites=1 \
--search-engine=opensearch \
--opensearch-host=opensearch \
--opensearch-port=9200 \
--opensearch-index-prefix=${STORE_PREFIX} \
--opensearch-timeout=15 \
--backend-frontname=${MAGENTO_ADMIN_FRONTNAME} \
$EXTRA_OPTS

# ── 14. Reload Nginx ──────────────────────────────────────────────────────────
echo "🔄 Starting/Reloading Nginx..."
docker compose up -d nginx

# ── 15. Summary ───────────────────────────────────────────────────────────────
echo ""
echo "✅ Everything is ready!!"
echo ""
echo "🛒 Store URL:   ${MAGENTO_BASE_URL}"
echo "🔧 Admin URL:   ${MAGENTO_BASE_URL}${MAGENTO_ADMIN_FRONTNAME}"
echo "👤 Admin user:  ${MAGENTO_ADMIN_USER}"
echo "🔑 Admin pass:  ${MAGENTO_ADMIN_PASSWORD}"
echo ""
